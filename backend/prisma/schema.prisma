generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  users       User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?

  users       User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id            Int         @id @default(autoincrement())

  firstName     String
  lastName      String

  email         String      @unique
  password      String

  phone         String?

  status        Boolean     @default(true)

  roleId        Int
  departmentId  Int

  role          Role        @relation(fields: [roleId], references: [id])
  department    Department  @relation(fields: [departmentId], references: [id])

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}